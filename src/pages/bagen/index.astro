<script>
  // Accordion
  (function () {
    function init() {
      document.querySelectorAll<HTMLButtonElement>('.rq-header[data-target]').forEach(header => {
        header.setAttribute('type', 'button');
        header.addEventListener('click', (e) => {
          e.preventDefault();
          const targetId = header.getAttribute('data-target')!;
          const body = document.getElementById(targetId);
          if (!body) return;
          const isOpen = header.getAttribute('aria-expanded') === 'true';
          document.querySelectorAll<HTMLButtonElement>('.rq-header[data-target]').forEach(h => {
            const tid = h.getAttribute('data-target')!;
            if (tid !== targetId) {
              h.setAttribute('aria-expanded', 'false');
              const b = document.getElementById(tid);
              if (b) b.style.maxHeight = '0px';
            }
          });
          if (isOpen) {
            header.setAttribute('aria-expanded', 'false');
            body.style.maxHeight = '0px';
          } else {
            header.setAttribute('aria-expanded', 'true');
            body.style.maxHeight = body.scrollHeight + 'px';
            body.querySelectorAll('img').forEach(img => {
              if (!img.complete) img.addEventListener('load', () => {
                if (header.getAttribute('aria-expanded') === 'true')
                  body.style.maxHeight = body.scrollHeight + 'px';
              }, { once: true });
            });
          }
        });
      });
    }
    document.readyState === 'loading' ? document.addEventListener('DOMContentLoaded', init) : init();
  })();

  // Copy citation
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('copy-button');
    const code = document.querySelector('.citation-block pre code');
    if (btn && code) {
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(code.textContent || '');
          btn.classList.add('copied');
          setTimeout(() => btn.classList.remove('copied'), 2000);
        } catch {
          btn.classList.add('copy-error');
          setTimeout(() => btn.classList.remove('copy-error'), 2000);
        }
      });
    }
  });

  // Title reveal animation
  document.addEventListener('DOMContentLoaded', () => {
    const el = document.getElementById('animated-title');
    if (el) {
      const text = el.textContent || '';
      el.innerHTML = '';
      text.split('').forEach((ch, i) => {
        const span = document.createElement('span');
        span.className = 'reveal-char';
        span.style.animationDelay = `${i * 0.08}s`;
        span.textContent = ch === ' ' ? ' ' : ch;
        el.appendChild(span);
      });
    }
  });
</script>

